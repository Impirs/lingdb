# Copy to .env and edit if needed:  cp .env.example .env

# Database connection (PostgreSQL 18)
DB_URL=postgresql://postgres:postgres@localhost:5432/lingdb_dev

# Directory with kaikki.org JSONL dumps (english.jsonl, german.jsonl, russian.jsonl)
DUMPS_DIR=D:/lingdb/dumps
# Where Stanza stores its models (downloaded once)
STANZA_DIR=D:/lingdb/stanza_resources

# Rows per INSERT transaction (Phase 1 import)
BATCH_SIZE=2000

# Store the raw dump record in source_records for reprocessing (1) or not (0)
STORE_RAW=0


# Phase 2 pass 4 (embedding attachment). MiniLM is fast/cached (CPU-feasible);
# set EMBED_MODEL=sentence-transformers/LaBSE for the proposal model (slow on CPU).
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_BATCH_SIZE=256
CONCEPT_SIM_THRESHOLD=0.75
